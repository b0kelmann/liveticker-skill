# LiveTicker — LLM Provider Configuration
#
# Pick ONE of the three GOSIM Hackathon providers below by uncommenting
# the matching block, copy this file to `.env`, and fill in your key.
#
# Get your key from create.gosim.org → "API Credits" card (after on-site check-in).

# ─── Option A: RouteTokens (GLM 5/5.1, DeepSeek v4-pro/flash) ───────────────
# Largest model selection. Requires separate registration at portal.routetokens.com
# with the SAME email you used on create.gosim.org.
LLM_API_KEY=
LLM_BASE_URL=https://api.r9s.ai/v1
LLM_MODEL=deepseek-v4-flash
# Other valid models: deepseek-v4-pro, glm-5, glm-5.1

# ─── Option B: Kimi (Moonshot k2.6) ─────────────────────────────────────────
# Single model, easiest setup. Key directly from create.gosim.org.
# LLM_API_KEY=
# LLM_BASE_URL=https://taotoken.net/api/v1
# LLM_MODEL=kimi-k2.6

# ─── Option C: MiniMax ──────────────────────────────────────────────────────
# Uses MiniMax's own SDK, NOT OpenAI-compatible. Redeem code at MiniMax Token
# Plan page first. The skill/llm.py adapter does not currently wrap MiniMax —
# add a separate code path if you go this route.
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
